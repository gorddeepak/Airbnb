<% layout("/layouts/boilerplate") %>
<div class=" mt-3 col-8 offset-2">
    <h3><%=listing.title%></h3>
</div>
<div class="card-listing col-8 offset-2" >
  <img src="<%=listing.image%>" class="card-img-top " alt="listing-image">
  <div class="card-body">
    <p class="card-text">
        <%=listing.description%> <br>
        &#8377;<%=listing.price.toLocaleString("en-In")%> <br>
        <%=listing.location%> <br>
        <%=listing.country%>
    </p>
  </div>
</div>
<div class="offset-2 btns">
    <form method="get" action="/listings/<%=listing._id%>/edit">
    <button class="btn btn-dark edit-btn">Edit</button>
</form>
<form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
    <button class="btn btn-dark offset-5 dlt-btn">Delete</button>
</form>
</div>
<hr>
<div class="col-8 offset-2">
    <h4>Leave a review:-</h4>
    <br>
    <form action="/listings/<%=listing._id%>/review" method="post" class="needs-validation" novalidate>
        <div>
            <label for="rating" class="form-label"> Rating</label>
            <input type="range" min="1" max="5" name="review[rating]" id="rating" class="form-range">
        </div>
        <br>
        <div>
            <label for="comment" class="form-label"> Comment</label>
            <textarea name="review[comment]" id="comment" placeholder="Enter a comment" cols="100" rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">
                Enter a Comment!
            </div>
            <div class="valid-feedback">
                Comment looks Good!
            </div>
        </div>
        <br>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr>
    <h4>Reviews:-</h4>
    <div class="row">
        <%for (let review of listing.review) {%>
            <div class="card col-5 ms-3 mb-3 ">
                <div class="card-body mt-3">
                    <h5 class="card-title">User Name</h5>
                    <p class="card-text"><%= review.comment %></p>
                    <p class="card-text"><%= review.rating %> Stars</p>
                    <form action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE" method="post">
                        <button class="btn btn-sm btn-dark mb-3" >Delete</button>
                    </form>
                </div>
            </div>
        <% } %>
    </div>
</div>



